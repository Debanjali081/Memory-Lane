# Core
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_extension_tool

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Embeddings / AI
EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TAG_MODEL=gpt-5-mini-2025-08-07
OPENAI_TAG_COUNT=5
OPENAI_RESURFACE_MODEL=gpt-5-mini-2025-08-07

# Tagging (dev TLS)
EXTRACT_ALLOW_INSECURE_TLS=false

# App
RESURFACE_CRON=0 9 * * 1


